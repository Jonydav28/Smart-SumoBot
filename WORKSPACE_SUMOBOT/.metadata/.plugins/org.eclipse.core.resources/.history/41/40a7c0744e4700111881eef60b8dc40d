/* USER CODE BEGIN 4 */
void set_pwm(uint32_t canal, int duty)
{
    if (duty < 0) duty = 0;
    if (duty > 100) duty = 100;

    uint32_t compare = (duty * PWM_MAX) / 100;
    __HAL_TIM_SET_COMPARE(&htim3, canal, compare);
}

void motor_izquierdo(int velocidad)
{
    if (velocidad > 100) velocidad = 100;
    if (velocidad < -100) velocidad = -100;

    if (velocidad > 0)
    {
        // Adelante
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_SET);   // AIN1
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_1, GPIO_PIN_RESET); // AIN2
        set_pwm(TIM_CHANNEL_1, velocidad);                    // PWMA
    }
    else if (velocidad < 0)
    {
        // Atrás
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_RESET); // AIN1
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_1, GPIO_PIN_SET);   // AIN2
        set_pwm(TIM_CHANNEL_1, -velocidad);                   // PWMA
    }
    else
    {
        // Detenido libre
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_RESET);
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_1, GPIO_PIN_RESET);
        set_pwm(TIM_CHANNEL_1, 0);
    }
}

void motor_derecho(int velocidad)
{
    if (velocidad > 100) velocidad = 100;
    if (velocidad < -100) velocidad = -100;

    if (velocidad > 0)
    {
        // Adelante
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);   // BIN1
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET); // BIN2
        set_pwm(TIM_CHANNEL_2, velocidad);                    // PWMB
    }
    else if (velocidad < 0)
    {
        // Atrás
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET); // BIN1
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);   // BIN2
        set_pwm(TIM_CHANNEL_2, -velocidad);                   // PWMB
    }
    else
    {
        // Detenido libre
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
        HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
        set_pwm(TIM_CHANNEL_2, 0);
    }
}


void mover_robot(int vel_izq, int vel_der)
{
    vel_obj_izq = vel_izq;
    vel_obj_der = vel_der;
}

void actualizar_rampa(void)
{
    if (vel_actual_izq < vel_obj_izq)
    {
        vel_actual_izq += RAMPA_PASO;
        if (vel_actual_izq > vel_obj_izq) vel_actual_izq = vel_obj_izq;
    }
    else if (vel_actual_izq > vel_obj_izq)
    {
        vel_actual_izq -= RAMPA_PASO;
        if (vel_actual_izq < vel_obj_izq) vel_actual_izq = vel_obj_izq;
    }

    if (vel_actual_der < vel_obj_der)
    {
        vel_actual_der += RAMPA_PASO;
        if (vel_actual_der > vel_obj_der) vel_actual_der = vel_obj_der;
    }
    else if (vel_actual_der > vel_obj_der)
    {
        vel_actual_der -= RAMPA_PASO;
        if (vel_actual_der < vel_obj_der) vel_actual_der = vel_obj_der;
    }

    motor_izquierdo(vel_actual_izq);
    motor_derecho(vel_actual_der);
}
void delay_us(uint16_t us)
{
    __HAL_TIM_SET_COUNTER(&htim4, 0);
    while (__HAL_TIM_GET_COUNTER(&htim4) < us);
}
uint32_t medir_ultrasonico(GPIO_TypeDef *TRIG_Port, uint16_t TRIG_Pin,
                           GPIO_TypeDef *ECHO_Port, uint16_t ECHO_Pin)
{
    uint32_t tiempo = 0;
    uint32_t timeout = 0;

    // Asegurar TRIG en bajo
    HAL_GPIO_WritePin(TRIG_Port, TRIG_Pin, GPIO_PIN_RESET);
    delay_us(2);

    // Pulso TRIG de 10 us
    HAL_GPIO_WritePin(TRIG_Port, TRIG_Pin, GPIO_PIN_SET);
    delay_us(10);
    HAL_GPIO_WritePin(TRIG_Port, TRIG_Pin, GPIO_PIN_RESET);

    // Esperar a que ECHO suba
    timeout = 0;
    while (HAL_GPIO_ReadPin(ECHO_Port, ECHO_Pin) == GPIO_PIN_RESET)
    {
        timeout++;
        if (timeout > 30000) return 999;
    }

    // Medir tiempo en alto
    __HAL_TIM_SET_COUNTER(&htim4, 0);

    timeout = 0;
    while (HAL_GPIO_ReadPin(ECHO_Port, ECHO_Pin) == GPIO_PIN_SET)
    {
        tiempo = __HAL_TIM_GET_COUNTER(&htim4);
        timeout++;
        if (timeout > 30000) return 999;
    }

    // Conversión aproximada a cm
    return tiempo / 58;
}
uint16_t leer_sharp_adc(void)
{
    uint16_t valor_adc = 0;

    HAL_ADC_Start(&hadc1);

    if (HAL_ADC_PollForConversion(&hadc1, 10) == HAL_OK)
    {
        valor_adc = HAL_ADC_GetValue(&hadc1);
    }

    HAL_ADC_Stop(&hadc1);

    return valor_adc;
}

void modo_autonomo_basico(void)
{
    adc_sharp = leer_sharp_adc();

    distancia_us_izq = medir_ultrasonico(TRIG_US_IZQ_GPIO_Port, TRIG_US_IZQ_Pin,
                                         ECHO_US_IZQ_GPIO_Port, ECHO_US_IZQ_Pin);

    HAL_Delay(50);

    distancia_us_der = medir_ultrasonico(TRIG_US_DER_GPIO_Port, TRIG_US_DER_Pin,
                                         ECHO_US_DER_GPIO_Port, ECHO_US_DER_Pin);

    uint8_t enemigo_frente = 0;
    uint8_t enemigo_izq = 0;
    uint8_t enemigo_der = 0;

    if (adc_sharp > SHARP_UMBRAL_ADC)
    {
        enemigo_frente = 1;
    }

    if (distancia_us_izq > 2 && distancia_us_izq < DIST_LATERAL_CM)
    {
        enemigo_izq = 1;
    }

    if (distancia_us_der > 2 && distancia_us_der < DIST_LATERAL_CM)
    {
        enemigo_der = 1;
    }

    if (enemigo_frente)
    {
        mover_robot(VEL_ATAQUE, VEL_ATAQUE);
    }
    else if (enemigo_izq && !enemigo_der)
    {
        mover_robot(VEL_GIRO_BAJA, VEL_GIRO_ALTA);
    }
    else if (enemigo_der && !enemigo_izq)
    {
        mover_robot(VEL_GIRO_ALTA, VEL_GIRO_BAJA);
    }
    else if (enemigo_izq && enemigo_der)
    {
        mover_robot(VEL_ATAQUE, VEL_ATAQUE);
    }
    else
    {
        mover_robot(VEL_BUSQUEDA, -VEL_BUSQUEDA);
    }
}

