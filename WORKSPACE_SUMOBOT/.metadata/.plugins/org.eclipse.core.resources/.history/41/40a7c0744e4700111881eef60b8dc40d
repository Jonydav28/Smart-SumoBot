void RGB_SetEstado(uint8_t estado)
{
    if (estado_rgb != estado)
    {
        estado_rgb = estado;
        tiempo_rgb = HAL_GetTick();
        rgb_toggle = 0;
    }
}

void RGB_PWM_Set(uint8_t r, uint8_t g, uint8_t b)
{
    if (r > 100) r = 100;
    if (g > 100) g = 100;
    if (b > 100) b = 100;

    uint32_t pwm_r = (r * 99) / 100;
    uint32_t pwm_g = (g * 99) / 100;
    uint32_t pwm_b = (b * 99) / 100;

    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, pwm_r); // PA1 rojo
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, pwm_g); // PA2 verde
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, pwm_b); // PA3 azul
}

void RGB_Off(void)
{
    RGB_PWM_Set(0, 0, 0);
}

void RGB_Rojo(void)
{
    RGB_PWM_Set(100, 0, 0);
}

void RGB_Verde(void)
{
    RGB_PWM_Set(0, 100, 0);
}

