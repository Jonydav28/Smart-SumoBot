void cambiar_modo_operacion(void)
{
    // Cambia al siguiente modo
    if (modo_operacion == MODO_TECNICO)
    {
        modo_operacion = MODO_ESPERA;
    }
    else if (modo_operacion == MODO_ESPERA)
    {
        modo_operacion = MODO_AUTONOMO;
    }
    else if (modo_operacion == MODO_AUTONOMO)
    {
        modo_operacion = MODO_REMOTO;
    }
    else
    {
        modo_operacion = MODO_TECNICO;
    }

    // Detener motores cada vez que se cambia de modo
    mover_robot(0, 0);
    motor_izquierdo(0);
    motor_derecho(0);
    vel_actual_izq = 0;
    vel_actual_der = 0;

    // Mostrar modo en OLED
    ssd1306_Fill(Black);
    ssd1306_SetCursor(0, 10);
    ssd1306_WriteString("MODO:", Font_7x10, White);

    if (modo_operacion == MODO_TECNICO)
    {
        ssd1306_SetCursor(0, 32);
        ssd1306_WriteString("TECNICO", Font_7x10, White);
        RGB_SetEstado(ESTADO_BT_CONTROL);   // Azul
    }
    else if (modo_operacion == MODO_ESPERA)
    {
        ssd1306_SetCursor(0, 32);
        ssd1306_WriteString("ESPERA", Font_7x10, White);
        RGB_SetEstado(ESTADO_ESPERA);       // Amarillo intermitente
    }
    else if (modo_operacion == MODO_AUTONOMO)
    {
        ssd1306_SetCursor(0, 32);
        ssd1306_WriteString("AUTONOMO", Font_7x10, White);
        RGB_SetEstado(ESTADO_AUTO);         // Verde
        buzzer_inicio();
    }
    else if (modo_operacion == MODO_REMOTO)
    {
        ssd1306_SetCursor(0, 32);
        ssd1306_WriteString("CONTROL REMOTO", Font_7x10, White);
        RGB_SetEstado(ESTADO_BT_CONTROL);   // Azul
    }

    ssd1306_UpdateScreen();
}


