void RGB_Estado(uint8_t estado)
{
    switch (estado)
    {
        case ESTADO_BT_CONTROL:
            RGB_Azul();          // Azul fijo
            break;

        case ESTADO_AUTO:
            RGB_Verde();         // Verde fijo
            break;

        case ESTADO_ESPERA:
            RGB_Amarillo();      // Luego lo hacemos intermitente
            break;

        case ESTADO_BATERIA_BAJA:
            RGB_Rojo();          // Luego intermitente
            break;

        case ESTADO_BT_SIN_EMPAREJAR:
            RGB_Morado();        // Luego intermitente
            break;

        case ESTADO_VICTORIA:
            RGB_Verde();         // Luego parpadeo rápido
            break;

        case ESTADO_DERROTA:
            RGB_Rojo();          // Rojo fijo
            break;

        case ESTADO_IMPACTO:
            RGB_Blanco();        // Blanco breve
            break;

        default:
            RGB_Off();
            break;
    }
}

void RGB_Impacto_Breve(void)
{
    impacto_activo = 1;
    tiempo_impacto_rgb = HAL_GetTick();
    RGB_Blanco();
}

void RGB_Actualizar(void)
{
    uint32_t ahora = HAL_GetTick();

    // Prioridad máxima: impacto blanco breve
    if (impacto_activo)
    {
        if (ahora - tiempo_impacto_rgb < 180)
        {
            RGB_Blanco();
            return;
        }
        else
        {
            impacto_activo = 0;
        }
    }

    switch (estado_rgb)
    {
        case ESTADO_BT_CONTROL:
            // Azul fijo
            RGB_Azul();
            break;

        case ESTADO_AUTO:
            // Verde fijo
            RGB_Verde();
            break;

        case ESTADO_ESPERA:
            // Amarillo intermitente lento
            if (ahora - tiempo_rgb >= 500)
            {
                tiempo_rgb = ahora;
                rgb_toggle = !rgb_toggle;
            }

            if (rgb_toggle)
                RGB_Amarillo();
            else
                RGB_Off();
            break;

        case ESTADO_BATERIA_BAJA:
            // Rojo intermitente
            if (ahora - tiempo_rgb >= 300)
            {
                tiempo_rgb = ahora;
                rgb_toggle = !rgb_toggle;
            }

            if (rgb_toggle)
                RGB_Rojo();
            else
                RGB_Off();
            break;

        case ESTADO_BT_SIN_EMPAREJAR:
            // Morado intermitente
            if (ahora - tiempo_rgb >= 400)
            {
                tiempo_rgb = ahora;
                rgb_toggle = !rgb_toggle;
            }

            if (rgb_toggle)
                RGB_Morado();
            else
                RGB_Off();
            break;

        case ESTADO_VICTORIA:
            // Verde parpadeo rápido
            if (ahora - tiempo_rgb >= 120)
            {
                tiempo_rgb = ahora;
                rgb_toggle = !rgb_toggle;
            }

            if (rgb_toggle)
                RGB_Verde();
            else
                RGB_Off();
            break;

        case ESTADO_DERROTA:
            // Rojo fijo
            RGB_Rojo();
            break;

        case ESTADO_IMPACTO:
            // Blanco fijo si se usa como estado, aunque es mejor usar RGB_Impacto_Breve()
            RGB_Blanco();
            break;

        default:
            RGB_Off();
            break;
    }
}

#define INA219_ADDR        (0x40 << 1)
#define INA219_REG_CONFIG  0x00
#define INA219_REG_SHUNT   0x01
#define INA219_REG_BUS     0x02
#define INA219_REG_POWER   0x03
#define INA219_REG_CURRENT 0x04
#define INA219_REG_CALIB   0x05

uint8_t INA219_WriteRegister(uint8_t reg, uint16_t value)
{
    uint8_t data[3];

    data[0] = reg;
    data[1] = (value >> 8) & 0xFF;
    data[2] = value & 0xFF;

    if (HAL_I2C_Master_Transmit(&hi2c1, INA219_ADDR, data, 3, 100) == HAL_OK)
        return 1;

    return 0;
}

uint8_t INA219_ReadRegister(uint8_t reg, uint16_t *value)
{
    uint8_t data[2];

    if (HAL_I2C_Master_Transmit(&hi2c1, INA219_ADDR, &reg, 1, 100) != HAL_OK)
        return 0;

    if (HAL_I2C_Master_Receive(&hi2c1, INA219_ADDR, data, 2, 100) != HAL_OK)
        return 0;

    *value = ((uint16_t)data[0] << 8) | data[1];

    return 1;
}

uint8_t INA219_Init(void)
{
    /*
     Configuración:
     - Bus hasta 32 V
     - Ganancia shunt ±320 mV
     - ADC 12 bits
     - Medición continua shunt + bus

     Calibración:
     - Shunt típico: 0.1 ohm
     - Current LSB aproximado: 100 uA
     - Entonces registro CURRENT queda en unidades de 0.1 mA
    */

    if (!INA219_WriteRegister(INA219_REG_CONFIG, 0x399F))
        return 0;

    if (!INA219_WriteRegister(INA219_REG_CALIB, 4096))
        return 0;

    return 1;
}

uint16_t INA219_ReadBusVoltage_mV(void)
{
    uint16_t raw = 0;

    if (!INA219_ReadRegister(INA219_REG_BUS, &raw))
        return 0;

    // Bits [15:3], cada bit equivale a 4 mV
    raw = raw >> 3;

    return raw * 4;
}

int16_t INA219_ReadCurrent_mA_x10(void)
{
    uint16_t raw_u = 0;

    if (!INA219_ReadRegister(INA219_REG_CURRENT, &raw_u))
        return 0;

    /*
     Con calibración 4096:
     1 bit del registro CURRENT ≈ 0.1 mA
     Por eso retornamos mA x10.
     Ejemplo:
     253 significa 25.3 mA
    */

    return (int16_t)raw_u;
}

void OLED_Mostrar_Bateria(uint16_t voltaje_mV, int16_t corriente_x10, uint8_t estado_bateria)
{
    char linea[24];

    ssd1306_Fill(Black);

    ssd1306_SetCursor(0, 0);
    ssd1306_WriteString("MONITOR BATERIA", Font_7x10, White);

    ssd1306_SetCursor(0, 16);
    sprintf(linea, "V: %u.%03u V", voltaje_mV / 1000, voltaje_mV % 1000);
    ssd1306_WriteString(linea, Font_7x10, White);

    ssd1306_SetCursor(0, 30);
    sprintf(linea, "I: %d.%d mA", corriente_x10 / 10, corriente_x10 % 10);
    ssd1306_WriteString(linea, Font_7x10, White);

    ssd1306_SetCursor(0, 48);

    if (estado_bateria == 0)
    {
        ssd1306_WriteString("Estado: OK", Font_7x10, White);
    }
    else if (estado_bateria == 1)
    {
        ssd1306_WriteString("Estado: MEDIA", Font_7x10, White);
    }
    else if (estado_bateria == 2)
    {
        ssd1306_WriteString("Estado: BAJA", Font_7x10, White);
    }
    else
    {
        ssd1306_WriteString("Estado: CRITICA", Font_7x10, White);
    }

    ssd1306_UpdateScreen();
}


void verificar_bateria(void)
{
    uint16_t voltaje_mV = INA219_ReadBusVoltage_mV();
    int16_t corriente_x10 = INA219_ReadCurrent_mA_x10();

    uint8_t estado_bateria = 0;

    if (voltaje_mV >= BAT_OK_MV)
    {
        estado_bateria = 0; // OK
        aviso_bateria_emitido = 0;
    }
    else if (voltaje_mV >= BAT_BAJA_MV)
    {
        estado_bateria = 1; // MEDIA
        aviso_bateria_emitido = 0;
    }
    else if (voltaje_mV >= BAT_CRITICA_MV)
    {
        estado_bateria = 2; // BAJA
        RGB_SetEstado(ESTADO_BATERIA_BAJA);

        if (aviso_bateria_emitido == 0)
        {
            buzzer_bateria_baja();
            aviso_bateria_emitido = 1;
        }
    }
    else
    {
        estado_bateria = 3; // CRITICA
        RGB_SetEstado(ESTADO_BATERIA_BAJA);

        if (aviso_bateria_emitido == 0)
        {
            buzzer_bateria_baja();
            aviso_bateria_emitido = 1;
        }

        mover_robot(0, 0); // opcional: detener motores por seguridad
    }

    OLED_Mostrar_Bateria(voltaje_mV, corriente_x10, estado_bateria);
}

