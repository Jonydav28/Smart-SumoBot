/* Implementación de Modos Tecnico y Competencia */

	   static uint32_t t_led = 0;
	    static uint32_t t_sensores = 0;
	    static uint32_t t_rampa = 0;
	    static uint32_t t_bateria = 0;

	    uint32_t ahora = HAL_GetTick();

	    // 1. Procesar pulsacion del boton con antirrebote
	    if (flag_boton_irq)
	    {
	        if (HAL_GetTick() - tiempo_boton_irq >= 50)
	        {
	            flag_boton_irq = 0;

	            // Confirmar que el boton sigue presionado
	            if (HAL_GPIO_ReadPin(BOTON_GPIO_Port, BOTON_Pin) == GPIO_PIN_RESET)
	            {
	                cambiar_modo_operacion();
	            }
	        }
	    }

	    // 2. Rearmar boton solo cuando se suelte
	    if (!boton_armado)
	    {
	        if (HAL_GPIO_ReadPin(BOTON_GPIO_Port, BOTON_Pin) == GPIO_PIN_SET)
	        {
	            if (HAL_GetTick() - tiempo_boton_irq >= 250)
	            {
	                boton_armado = 1;
	            }
	        }
	    }

	    // 3. LED PC13 indicador de vida
	    if (ahora - t_led >= 500)
	    {
	        t_led = ahora;
	        HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
	    }

	    // 4. Actualizar RGB siempre
	    RGB_Actualizar();

	    // 5. Revisar bateria cada 1 segundo
	    if (ahora - t_bateria >= 1000)
	    {
	        t_bateria = ahora;
	        verificar_bateria();
	    }
	    // 6. Modos

	    if (bateria_critica)
	    {
	        mover_robot(0, 0);
	        motor_izquierdo(0);
	        motor_derecho(0);
	        vel_actual_izq = 0;
	        vel_actual_der = 0;

	        RGB_SetEstado(ESTADO_BATERIA_BAJA);
	    }
	    else if (modo_operacion == MODO_TECNICO)
	    {
	        // Modo de pruebas y diagnostico
	        mover_robot(0, 0);
	        motor_izquierdo(0);
	        motor_derecho(0);
	        vel_actual_izq = 0;
	        vel_actual_der = 0;

	        // Aquí puedes mostrar sensores, bateria, etc.
	    }
	    else if (modo_operacion == MODO_ESPERA)
	    {
	        // Esperando señal de inicio
	        mover_robot(0, 0);
	        motor_izquierdo(0);
	        motor_derecho(0);
	        vel_actual_izq = 0;
	        vel_actual_der = 0;

	        RGB_SetEstado(ESTADO_ESPERA);
	    }
	    else if (modo_operacion == MODO_AUTONOMO)
	    {
	        // Modo de combate autonomo
	        if (ahora - t_sensores >= 80)
	        {
	            t_sensores = ahora;
	            modo_autonomo_basico();
	        }

	        if (ahora - t_rampa >= 10)
	        {
	            t_rampa = ahora;
	            actualizar_rampa();
	        }
	    }
	    else if (modo_operacion == MODO_REMOTO)
	    {
	        // Modo control remoto por Bluetooth
	        // Por ahora puedes dejar motores detenidos hasta integrar UART/Bluetooth

	        mover_robot(0, 0);
	        motor_izquierdo(0);
	        motor_derecho(0);
	        vel_actual_izq = 0;
	        vel_actual_der = 0;

	        RGB_SetEstado(ESTADO_BT_CONTROL);

	        // Luego aquí irá la lectura de comandos Bluetooth:
	        // comando = leer_bluetooth();
	        // ejecutar_comando_bluetooth(comando);
	    }



